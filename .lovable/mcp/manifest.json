{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "agrobusiness-mcp",
      "version": "0.1.0",
      "title": "AGROBUSINESS MCP"
    },
    "tools": [
      {
        "name": "list_noticias",
        "title": "List agro news",
        "description": "List the latest Brazilian agribusiness news collected by AGROBUSINESS.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 10,
              "description": "How many news items to return (1-50)."
            },
            "tema": {
              "type": "string",
              "description": "Optional theme filter (e.g. soja, milho, cafe, boi)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_cotacao_dolar",
        "title": "Get USD/BRL quote",
        "description": "Get the latest USD/BRL exchange rate tracked by AGROBUSINESS.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "tipo": {
              "type": "string",
              "enum": [
                "comercial",
                "turismo",
                "paralelo"
              ],
              "default": "comercial",
              "description": "Which USD quote type to fetch."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_anuncios",
        "title": "List marketplace listings",
        "description": "List active public marketplace ads (anúncios) on AGROBUSINESS.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 10,
              "description": "How many ads to return (1-50)."
            },
            "categoria": {
              "type": "string",
              "description": "Optional category filter (e.g. fruta, grao, legumes, vegetal)."
            },
            "produto": {
              "type": "string",
              "description": "Optional product name filter (case-insensitive contains)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
